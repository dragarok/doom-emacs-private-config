           "%?"
           :file-name "%<%Y%m%d%H%M%S>-${slug}"
           :head "#+HUGO_SECTION: post
#+HUGO_BASE_DIR: /c/Users/sagar/Dropbox/org/blogging/
#+HUGO_TAGS: %^{Tags}
#+EXPORT_FILE_NAME: %^{export name}
#+TITLE: ${title}
#+AUTHOR: Suan-sing Tan
#+DATE: %t"
           :unnarrowed t)
          ))
  (org-roam-mode +1))






